<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ระบบตรวจสอบยอดค่าตอบแทนเจ้าหน้าที่</title>
    <!-- Tailwind CSS สำหรับตกแต่ง -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- PapaParse สำหรับอ่านไฟล์ CSV จาก Google Sheets -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.4.1/papaparse.min.js"></script>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Prompt', sans-serif;
            background-color: #f3f4f6;
        }
        .loader {
            border-top-color: #3b82f6;
            -webkit-animation: spinner 1.5s linear infinite;
            animation: spinner 1.5s linear infinite;
        }
        @keyframes spinner {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">

    <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-6 sm:p-8">
        <!-- Header -->
        <div class="text-center mb-8">
            <img src="https://raw.githubusercontent.com/FinanceNangRong/Check-compensation/main/NRHOS.png" alt="Logo" class="mx-auto h-24 w-auto object-contain mb-4 rounded-xl shadow-sm border border-gray-100 p-2">
            <h1 class="text-2xl font-bold text-gray-800">เช็คยอดค่าตอบแทน</h1>
            <p class="text-sm text-gray-500 mt-1">กรุณากรอกเลขประจำตัวประชาชน 13 หลัก</p>
        </div>

        <!-- System Loading Status -->
        <div id="loadingStatus" class="flex flex-col items-center justify-center py-4 mb-4">
            <div class="loader ease-linear rounded-full border-4 border-t-4 border-gray-200 h-10 w-10 mb-3"></div>
            <p class="text-sm text-blue-600 font-medium">กำลังเชื่อมต่อฐานข้อมูล...</p>
        </div>

        <!-- Search Form (Hidden until data is loaded) -->
        <div id="searchForm" class="hidden">
            <div class="mb-4">
                <input type="text" id="idInput" maxlength="13" placeholder="เลขบัตรประชาชน 13 หลัก" 
                       class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition text-center text-lg tracking-widest">
            </div>
            <button onclick="searchData()" id="searchBtn" 
                    class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-4 rounded-xl shadow-md transition duration-200 flex justify-center items-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                ค้นหาข้อมูล
            </button>
        </div>

        <!-- Error Message -->
        <div id="errorMsg" class="hidden mt-4 p-3 bg-red-50 border-l-4 border-red-500 text-red-700 text-sm rounded">
            ไม่พบข้อมูล หรือกรอกเลขบัตรประชาชนไม่ถูกต้อง
        </div>

        <!-- Result Section -->
        <div id="resultSection" class="hidden mt-6 pt-6 border-t border-gray-100">
            <div class="bg-blue-50 rounded-xl p-4 mb-4">
                <p class="text-xs text-blue-500 font-semibold uppercase tracking-wider mb-1">ชื่อ - นามสกุล</p>
                <p id="resName" class="text-lg font-bold text-gray-800"></p>
                <p id="resPosition" class="text-sm text-gray-600 mt-1"></p>
            </div>

            <h3 class="text-sm font-semibold text-gray-600 mb-3 flex items-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                ค่าตอบแทนคลินิคพิเศษนอกเวลาราชการ (SMC)
            </h3>
            
            <ul id="resDetails" class="space-y-2 mb-4 max-h-48 overflow-y-auto pr-2">
                <!-- Data will be injected here -->
            </ul>

            <div class="bg-gray-800 text-white rounded-xl p-4 flex justify-between items-center shadow-inner">
                <span class="font-medium text-gray-300">รวมยอดสุทธิ</span>
                <span id="resTotal" class="text-xl font-bold text-green-400">0.00 ฿</span>
            </div>
        </div>

        <!-- Footer Note -->
        <p class="text-xs text-center text-gray-400 mt-8">
            ข้อมูลอัปเดตอัตโนมัติจากฐานข้อมูลกลาง
        </p>
    </div>

    <script>
        // แปลงลิงก์ pubhtml เป็นรูปแบบ CSV เพื่อให้อ่านด้วย Javascript ได้ง่าย
        const csvUrl = "https://docs.google.com/spreadsheets/d/e/2PACX-1vQDitAbZGYODJihULiOMrHGWnKXHjdUL7cWbNTGgIEuJ0M9tHBJ-IItwauZyMTisw/pub?output=csv";
        
        let sheetData = [];
        let headers = [];

        // ฟังก์ชันเริ่มต้น: โหลดข้อมูลจาก Google Sheet ทันทีที่เปิดหน้าเว็บ
        document.addEventListener('DOMContentLoaded', () => {
            fetchData();
        });

        function fetchData() {
            Papa.parse(csvUrl, {
                download: true,
                skipEmptyLines: true,
                complete: function(results) {
                    if (results.data && results.data.length > 0) {
                        sheetData = results.data;
                        // สมมติว่าแถวแรก (index 0) คือ Header (หัวคอลัมน์)
                        headers = sheetData[0]; 
                        
                        // ปิด Loader และแสดงฟอร์มค้นหา
                        document.getElementById('loadingStatus').classList.add('hidden');
                        document.getElementById('searchForm').classList.remove('hidden');
                    } else {
                        showError("ไม่สามารถดึงข้อมูลจากฐานข้อมูลได้ กรุณาลองใหม่ภายหลัง");
                    }
                },
                error: function(err) {
                    showError("เกิดข้อผิดพลาดในการเชื่อมต่อฐานข้อมูล: " + err);
                }
            });
        }

        function searchData() {
            // ซ่อนผลลัพธ์และข้อความผิดพลาดก่อนค้นหาใหม่
            hideResult();
            
            // รับค่าจากช่อง Input และตัดช่องว่าง/ตัวอักษรที่ไม่ใช่ตัวเลขออก
            const rawInput = document.getElementById('idInput').value;
            const searchId = rawInput.replace(/\D/g, ''); // เก็บเฉพาะตัวเลข

            if (searchId.length === 0) {
                showError("กรุณากรอกเลขบัตรประชาชน");
                return;
            }

            // ค้นหาแถวที่คอลัมน์ B (Index 1) ตรงกับข้อมูลที่ค้นหา
            // ข้ามแถวที่ 0 เพราะเป็น Header
            const foundRow = sheetData.find((row, index) => {
                if (index === 0) return false; 
                if (!row[1]) return false; // ถ้าเซลล์นั้นว่าง
                
                // ลบช่องว่างหรือขีดออกเผื่อคนกรอกข้อมูลใน Sheet ติดขีด
                const cleanIdInSheet = row[1].toString().replace(/\D/g, '');
                return cleanIdInSheet === searchId;
            });

            if (foundRow) {
                displayResult(foundRow);
            } else {
                showError("ไม่พบข้อมูลของเลขบัตรประชาชนนี้ในระบบ");
            }
        }

        function displayResult(row) {
            // คอลัมน์ D คือ Index 3 (เริ่มนับจาก 0: A=0, B=1, C=2, D=3)
            const name = row[3] || "ไม่พบชื่อในระบบ";
            document.getElementById('resName').textContent = name;

            // คอลัมน์ E คือ Index 4 (ตำแหน่ง)
            const position = row[4] || "ไม่ระบุตำแหน่ง";
            document.getElementById('resPosition').textContent = "ตำแหน่ง: " + position;

            let detailsHTML = "";
            let totalAmount = 0;

            // คอลัมน์ G คือ Index 6 เป็นต้นไป
            // วนลูปเริ่มตั้งแต่ Index 6 จนจบแถว
            for (let i = 6; i < row.length; i++) {
                let valStr = row[i] || "0";
                // เอาเครื่องหมายคอมม่า (,) ออกเพื่อแปลงเป็นตัวเลข
                let valNum = parseFloat(valStr.replace(/,/g, ''));
                
                // ถ้าเป็นตัวเลขและมีค่ามากกว่า 0
                if (!isNaN(valNum) && valNum > 0) {
                    let monthName = headers[i] || `งวดที่ ${i - 5}`;
                    totalAmount += valNum;

                    // รูปแบบการแสดงผลแต่ละเดือน
                    detailsHTML += `
                        <li class="flex justify-between items-center bg-white border border-gray-100 p-3 rounded-lg shadow-sm">
                            <span class="text-gray-600 text-sm">${monthName}</span>
                            <span class="text-blue-600 font-semibold">${formatCurrency(valNum)} ฿</span>
                        </li>
                    `;
                }
            }

            const detailsContainer = document.getElementById('resDetails');
            if (detailsHTML === "") {
                detailsContainer.innerHTML = `<li class="text-center text-gray-500 text-sm py-4">ไม่มีประวัติยอดเงิน</li>`;
            } else {
                detailsContainer.innerHTML = detailsHTML;
            }

            document.getElementById('resTotal').textContent = `${formatCurrency(totalAmount)} ฿`;
            
            // แสดงผล
            document.getElementById('resultSection').classList.remove('hidden');
        }

        function showError(message) {
            const errDiv = document.getElementById('errorMsg');
            errDiv.textContent = message;
            errDiv.classList.remove('hidden');
        }

        function hideResult() {
            document.getElementById('resultSection').classList.add('hidden');
            document.getElementById('errorMsg').classList.add('hidden');
        }

        // ตัวแปลงตัวเลขให้มีคอมม่า (เช่น 1,000.00)
        function formatCurrency(number) {
            return new Intl.NumberFormat('th-TH', { 
                minimumFractionDigits: 2, 
                maximumFractionDigits: 2 
            }).format(number);
        }

        // อนุญาตให้กด Enter เพื่อค้นหาได้
        document.getElementById("idInput").addEventListener("keypress", function(event) {
            if (event.key === "Enter") {
                event.preventDefault();
                searchData();
            }
        });
    </script>
</body>
</html>
